# LinteR-LM — DeepSeek API backend (instance: deepseek, port 8098)
# Copy to .env.deepseek and fill in your key
LINTR_BACKEND_URL=https://api.deepseek.com
LINTR_BACKEND_API_KEY=sk-your-key-here
LINTR_HOST=127.0.0.1
LINTR_PORT=8098
LINTR_INTENSITY=mild
LINTR_DEBUG=0

# Context inject off — no local embedding server for remote API.
# Re-enable if you run an embedding server alongside.
LINTR_CONTEXT_INJECT=0
LINTR_TOOL_REPAIR=1
