# LinteR-LM — local Ollama backend (instance: local, port 8099)
# Copy to .env.local
LINTR_BACKEND_URL=http://127.0.0.1:11434
LINTR_BACKEND_API_KEY=
LINTR_HOST=127.0.0.1
LINTR_PORT=8099
LINTR_INTENSITY=mild
LINTR_DEBUG=0
LINTR_CONTEXT_INJECT=1
LINTR_TOOL_REPAIR=1

